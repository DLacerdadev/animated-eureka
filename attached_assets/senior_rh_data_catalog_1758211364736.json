  {
    "table_code": "R034FUN",
    "table_name": "Colaborador (Ficha Básica)",
    "module": "RH/Folha (Rubi/HCM)",
    "entity": "employee",
    "grain": "1 row por colaborador ativo/inativo por vínculo",
    "purpose": "Cadastro mestre do empregado para relatórios, integrações e folhas.",
    "logical_keys": [
      "employee_id",
      "company_id"
    ],
    "physical_key_hints": {
      "employee_id": "R034FUN.<id_do_colaborador>  # preencha com o campo usado na sua base (varia por versão)",
      "company_id": "R034FUN.<id_empresa>  # normalmente referencia a empresa da R030EMP"
    },
    "pii_fields_examples": [
      "nome",
      "cpf",
      "data_nascimento",
      "endereco"
    ],
    "sensitivity": "ALTA (PII)",
    "relationships": [
      {
        "to_table": "R030EMP",
        "on": [
          "company_id"
        ],
        "type": "many-to-one"
      },
      {
        "to_table": "R030FIL",
        "on": [
          "branch_id"
        ],
        "type": "many-to-one"
      },
      {
        "to_table": "R038HSA",
        "on": [
          "employee_id",
          "company_id"
        ],
        "type": "one-to-many"
      },
      {
        "to_table": "R038HCA",
        "on": [
          "employee_id",
          "company_id"
        ],
        "type": "one-to-many"
      },
      {
        "to_table": "R034CPL",
        "on": [
          "employee_id",
          "company_id"
        ],
        "type": "one-to-one"
      },
      {
        "to_table": "R034PPP",
        "on": [
          "employee_id",
          "company_id"
        ],
        "type": "one-to-many"
      }
    ],
    "common_filters": [
      "empresa",
      "filial",
      "situacao_funcional",
      "data_admissao >= X"
    ],
    "typical_joins": [
      "R034FUN.employee_id = R038HSA.employee_id",
      "R034FUN.company_id = R030EMP.company_id",
      "R034FUN.branch_id = R030FIL.branch_id"
    ],
    "notes": "Use como dimensão 'Colaborador'. Mapeie os campos físicos (id, empresa, filial) conforme sua instância."
  },
